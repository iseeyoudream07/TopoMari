# Leave KOMARI_BASE_URL empty to run the built-in animated demo.
KOMARI_BASE_URL=

# Optional headers for a private Komari instance. Never put these values in frontend files.
KOMARI_COOKIE=
KOMARI_AUTHORIZATION=

# Komari administrator API key. Required only for MaxMind GeoIP status,
# database updates, and server-side node-IP lookup. It is never sent to browsers.
KOMARI_API_KEY=

# Dashboard server settings.
PORT=3000
# systemd/Nginx deployments should listen only on loopback. Docker Compose
# overrides this inside the container while keeping the published port local.
HOST=127.0.0.1
KOMARI_TIMEOUT_MS=8000
CACHE_TTL_SECONDS=8

# Komari /api/nodes may update its timestamp every few minutes. Nodes with a
# newer updated_at/last_seen value are considered online by this dashboard.
NODE_ONLINE_THRESHOLD_SECONDS=600

# Private probe ingestion and SQLite history.
PROBE_DB_PATH=./data/probes.db
PROBE_RETENTION_DAYS=7
AGENT_CONFIG_PATH=./config/agents.json
# Redundant runtime copy used to restore Agent token hashes if an upgrade loses
# config/agents.json while the persistent data volume is still intact.
AGENT_BACKUP_PATH=./data/agents.backup.json
# Copy config/topology.example.json to this ignored runtime path before starting.
TOPOLOGY_CONFIG_PATH=./config/topology.json
MAX_INGEST_BODY_BYTES=32768
INGEST_RATE_LIMIT_PER_MINUTE=120
ENROLL_RATE_LIMIT_PER_MINUTE=20
MAX_EDITOR_BODY_BYTES=131072
MAX_FAVICON_BYTES=2097152
SITE_FAVICON_PATH=./data/favicon
MAX_THEME_BACKGROUND_BYTES=33554432
THEME_ASSET_DIR=./data/theme/user-assets

# The public dashboard does not require a login. These credentials protect
# /admin and all management APIs; live mode requires both unless the explicit
# no-admin override below is enabled.
DASHBOARD_USER=
DASHBOARD_PASSWORD=
ALLOW_UNAUTHENTICATED_DASHBOARD=false
ADMIN_SESSION_TTL_SECONDS=604800
ADMIN_LOGIN_RATE_LIMIT_PER_5_MINUTES=10

# Sanitized /api/nodes and /api/ping-tasks diagnostics are disabled by default.
ENABLE_DIAGNOSTIC_API=false

# Admin route editor. It is automatically disabled unless the admin credentials
# above are both configured.
ENABLE_TOPOLOGY_EDITOR=true

# Force demo mode even when KOMARI_BASE_URL is configured.
DEMO_MODE=false
